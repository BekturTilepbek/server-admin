# Скопируйте в .env и заполните. .env НИКОГДА не коммитится.

# Токен бота от @BotFather (старый считайте скомпрометированным — перевыпустите)
BOT_TOKEN=123456:PASTE_NEW_TOKEN_HERE

# Ваш Telegram ID
ADMIN_ID=918924643

# ID группы для уведомлений (у супергрупп обычно начинается с -100...)
GROUP_CHAT_ID=-1001234567890

# Мастер-ключ шифрования servers.json/users.json.
# Сгенерировать: python -c "from services.crypto import generate_key; print(generate_key())"
MASTER_KEY=PASTE_FERNET_KEY_HERE

# Аккаунты DigitalOcean для мониторинга биллинга (необязательно).
# Формат: почта1:токен,почта2:токен,почта3:токен
# Токен — персональный, read-only достаточно (начинается с dop_v1_).
# Создать: панель DO -> API -> Tokens -> Generate New Token (scope: Read).
DO_ACCOUNTS=main@example.com:dop_v1_xxx,client@example.com:dop_v1_yyy,backup@example.com:dop_v1_zzz
